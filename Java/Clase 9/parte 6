import java.util.Scanner;

public class Ejercicio3 {
    public static void main(String[] args) {
        Scanner entrada = new Scanner(System.in);

        // Pedimos al usuario la calificación
        System.out.println("Digite un número entre 0 y 10: ");
        var calificacion = Integer.parseInt(entrada.nextLine());

        // Sistema de evaluación por rangos
        if (calificacion >= 9 && calificacion <= 10) {
            System.out.println("A");
        } else if (calificacion >= 8 && calificacion < 9) {
            System.out.println("B");
        } else if (calificacion >= 7 && calificacion < 8) {
            System.out.println("C");
        } else if (calificacion >= 6 && calificacion < 7) {
            System.out.println("D");
        } else if (calificacion >= 0 && calificacion < 6) {
            System.out.println("F");
        } else {
            // Maneja números negativos o mayores a 10 para evitar fallos
            System.out.println("Valor desconocido / Calificación no válida");
        }

        entrada.close();
    }
