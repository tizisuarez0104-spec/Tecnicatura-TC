import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        // Creamos el objeto Scanner para leer los datos de la consola
        Scanner entrada = new Scanner(System.in);

        // Pedimos y leemos el nombre del libro
        System.out.println("Digite el nombre del libro: ");
        String nombre = entrada.nextLine();

        // Pedimos y leemos el autor
        System.out.println("Digite el autor del libro: ");
        String autor = entrada.nextLine();

        // Pedimos y leemos el código ISBN
        System.out.println("Digite el código (ISBN): ");
        String codigo = entrada.nextLine();

        // Pedimos y leemos el ID convirtiendo el texto a entero (como en la foto)
        System.out.println("Digite el id del libro: ");
        int idLibro = Integer.parseInt(entrada.nextLine());

        // Pedimos y leemos el precio convirtiendo a número decimal
        System.out.println("Digite el precio del libro: ");
        double precio = Double.parseDouble(entrada.nextLine());

        // Pedimos y leemos si el envío es gratuito (acepta "true" o "false")
        System.out.println("Confirme si el envío es gratuito (true/false): ");
        boolean envioGratuito = Boolean.parseBoolean(entrada.nextLine());

        
        System.out.println("      DATOS DEL LIBRO       ");
        System.out.println("Nombre: " + nombre);
        System.out.println("Autor: " + autor);
        System.out.println("Código (ISBN): " + codigo);
        System.out.println("ID del libro: " + idLibro);
        System.out.println("Precio: $" + precio);
        System.out.println("¿Envío gratuito?: " + envioGratuito);
        
        // Cerramos el scanner (buena práctica en Java)
        entrada.close();
    }
}
