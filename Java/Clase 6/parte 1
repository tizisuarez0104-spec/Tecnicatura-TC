public class BooleanPrintfExample {
   public static void main(String[] args) {
       boolean isGreen = true;
       System.out.printf("Apple is green: %b%n", isGreen); // lowercase
       System.out.printf("Apple is green: %B%n", isGreen); // uppercase
       isGreen = false;
       System.out.printf("Apple is green: %b%n", isGreen);
       System.out.printf("Apple is green: %B%n", isGreen);

